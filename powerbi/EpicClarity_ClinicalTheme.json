{
  "name": "Epic Clarity Clinical Theme",
  "dataColors": [
    "#2E7BA8",
    "#5BA4CF",
    "#1F3A5F",
    "#4A7C59",
    "#C44536",
    "#6B7280",
    "#8FB8D6",
    "#3D5A80"
  ],
  "background": "#F7F9FB",
  "foreground": "#1F3A5F",
  "tableAccent": "#2E7BA8",
  "good": "#4A7C59",
  "neutral": "#6B7280",
  "bad": "#C44536",
  "maximum": "#1F3A5F",
  "center": "#5BA4CF",
  "minimum": "#F7F9FB",
  "null": "#E5E7EB",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16,
      "color": "#1F3A5F"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#1F3A5F"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#6B7280"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 28,
      "color": "#1F3A5F"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E5E7EB" } },
            "radius": 4
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#1F3A5F" } },
            "fontSize": 13,
            "fontFamily": "Segoe UI Semibold",
            "alignment": "left"
          }
        ],
        "categoryAxis": [
          {
            "showAxisTitle": false,
            "color": { "solid": { "color": "#6B7280" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI",
            "gridlineColor": { "solid": { "color": "#E5E7EB" } },
            "gridlineStyle": "solid",
            "gridlineThickness": 1
          }
        ],
        "valueAxis": [
          {
            "showAxisTitle": false,
            "color": { "solid": { "color": "#6B7280" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI",
            "gridlineColor": { "solid": { "color": "#E5E7EB" } },
            "gridlineStyle": "solid",
            "gridlineThickness": 1
          }
        ],
        "legend": [
          {
            "fontSize": 10,
            "fontFamily": "Segoe UI",
            "labelColor": { "solid": { "color": "#1F3A5F" } },
            "position": "Top"
          }
        ],
        "labels": [
          {
            "fontSize": 10,
            "fontFamily": "Segoe UI",
            "color": { "solid": { "color": "#1F3A5F" } }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F7F9FB" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#F7F9FB" } }
          }
        ]
      }
    },
    "card": {
      "*": {
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#6B7280" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#1F3A5F" } },
            "fontSize": 32,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#E5E7EB" } },
            "outlineColor": { "solid": { "color": "#E5E7EB" } }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#1F3A5F" } },
            "backColor": { "solid": { "color": "#F7F9FB" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#1F3A5F" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    }
  }
}
